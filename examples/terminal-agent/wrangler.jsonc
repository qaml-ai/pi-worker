{
  "name": "terminal-agent",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "CF_ACCOUNT_ID": "85bbd288051330fb51ee1c86031a299b",
    "CF_GATEWAY_NAME": "chiridion",
    "AI_GATEWAY_MODEL": "dynamic/pi"
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "services": [
    {
      "binding": "OUTBOUND",
      "service": "terminal-agent-outbound"
    }
  ],
  "routes": [
    {
      "pattern": "pi.camelai.app",
      "custom_domain": true,
      "zone_name": "camelai.app"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "SESSIONS",
        "class_name": "TerminalSessionV2"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["TerminalSession"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["TerminalSessionV2"]
    }
  ]
}
