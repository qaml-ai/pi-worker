{
  "name": "pi-worker",
  "version": "0.1.0",
  "description": "Run pi-mono coding agents in Cloudflare Workers with R2-backed file tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.60.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@sinclair/typebox": "^0.34.41",
    "diff": "^8.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/diff": "^8.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "keywords": ["cloudflare", "workers", "agent", "ai", "pi-mono", "r2"],
  "license": "MIT"
}
