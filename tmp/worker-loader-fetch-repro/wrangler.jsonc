{
  "name": "worker-loader-fetch-repro",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "services": [
    {
      "binding": "OUTBOUND",
      "service": "worker-loader-fetch-repro-outbound"
    }
  ]
}
